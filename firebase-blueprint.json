{
  "entities": {
    "RemoteUpload": {
      "title": "Remote Upload",
      "description": "A file uploaded remotely from a phone to be viewed on a TV.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "deviceId": { "type": "string", "description": "The target TV device ID" },
        "type": { "type": "string", "enum": ["image", "audio", "video"] },
        "url": { "type": "string", "format": "uri" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "completed"] }
      },
      "required": ["deviceId", "type", "url", "createdAt"]
    },
    "DevicePairing": {
      "title": "Device Pairing",
      "description": "Information about a paired device session.",
      "type": "object",
      "properties": {
        "deviceId": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["deviceId", "lastActive"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User statistics and rewards.",
      "type": "object",
      "properties": {
        "xp": { "type": "number" },
        "coins": { "type": "number" },
        "donations": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Lesson": {
      "title": "Lesson",
      "description": "A customized memorization task or Quranic lesson.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["quran", "custom"] },
        "lang": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "text", "createdAt"]
    },
    "TVSession": {
      "title": "TV Session",
      "description": "A session for pairing a mobile device with a TV.",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "deviceId": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "linked"] },
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["status", "createdAt"]
    }
  },
  "firestore": {
    "/uploads/{uploadId}": {
      "schema": "RemoteUpload",
      "description": "Collection of remote uploads"
    },
    "/pairings/{deviceId}": {
      "schema": "DevicePairing",
      "description": "Collection of active device pairings"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data"
    },
    "/users/{userId}/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "User specific tasks and lessons"
    },
    "/tv_sessions/{sessionId}": {
      "schema": "TVSession",
      "description": "Collection of TV pairing sessions"
    }
  }
}
