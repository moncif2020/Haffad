// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: uploads
// Document ID: auto-generated
// Fields:
//   - deviceId: string (required) - The target TV device ID
//   - type: string (required, enum: ['image', 'audio', 'video'])
//   - url: string (required, format: uri)
//   - name: string (optional)
//   - createdAt: timestamp (required)
//   - status: string (optional, enum: ['pending', 'completed'])
//
// Collection: pairings
// Document ID: deviceId
// Fields:
//   - deviceId: string (required)
//   - lastActive: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🔒 Default Deny: الرفض الافتراضي لأي محاولة وصول غير مصرح بها.
    match /{document=**} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════
    // Helper Functions (دوال المساعدة)
    // ═══════════════════════════════════════
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && 
             id.size() > 0 &&
             id.size() <= 128 && 
             id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUrl(url) {
      return url is string && 
             url.size() >= 10 &&
             url.size() <= 2048 &&
             (url.matches('^https://.*') || url.matches('^http://.*'));
    }

    function isValidProfileData(data) {
      return data.displayName is string &&
             data.displayName.size() > 0 &&
             data.displayName.size() <= 255 &&
             data.photoURL is string &&
             data.photoURL.size() <= 2048;
    }

    function isValidRemoteUpload(data) {
      return data.keys().hasAll(['deviceId', 'type', 'url', 'createdAt', 'userId']) &&
             isValidId(data.deviceId) &&
             data.type in ['image', 'audio', 'video'] &&
             isValidUrl(data.url) &&
             data.userId is string &&
             data.userId.size() > 0 &&
             data.createdAt is timestamp &&
             data.createdAt <= request.time;
    }

    function isValidTVSession(data) {
      return data.keys().hasAll(['status', 'deviceId', 'createdAt']) &&
             data.status in ['waiting', 'linked'] &&
             isValidId(data.deviceId) &&
             data.createdAt is timestamp &&
             data.createdAt <= request.time &&
             (data.get('currentAnonUid', '') is string);
    }

    // ═══════════════════════════════════════
    // Users Collection (مجموعة المستخدمين)
    // ═══════════════════════════════════════
    
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      
      allow create: if isOwner(userId) &&
                       request.resource.data.keys().hasAll(['xp', 'coins', 'donations']) &&
                       request.resource.data.xp is number &&
                       request.resource.data.coins is number &&
                       request.resource.data.donations is number;
      
      allow update: if isOwner(userId) &&
                       // السماح بالتحديث الأولي للبيانات أو التحديثات اللاحقة
                       (
                         !resource.data.keys().hasAll(['xp', 'coins', 'donations']) ||
                         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdAt'])
                       );
      
      allow delete: if isOwner(userId);

      // 📚 Lessons Sub-Collection
      match /lessons/{lessonId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ═══════════════════════════════════════
    // Remote Uploads Collection (المرفوعات عن بعد)
    // ═══════════════════════════════════════
    
    match /uploads/{uploadId} {
      // السماح بالقراءة للصاحب أو إذا كان الجهاز يحمل الـ id الصحيح (للعرض على التلفاز)
      allow get: if isValidId(uploadId) && (
        (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.get('deviceId', '') != '')) ||
        (resource.data.get('deviceId', '') != '')
      );
      
      allow list: if (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.get('deviceId', '') != '')) ||
                     (resource.data.get('deviceId', '') != '');

      allow create: if isSignedIn() && 
                       isValidRemoteUpload(request.resource.data) &&
                       request.resource.data.userId == request.auth.uid;
      
      allow delete: if (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.get('deviceId', '') != '')) ||
                       (resource.data.get('deviceId', '') != '');
      
      allow update: if false;
    }

    // ═══════════════════════════════════════
    // TV Sessions Collection (Pairing - ربط الأجهزة)
    // ═══════════════════════════════════════
    
    match /tv_sessions/{sessionId} {
      allow get: if isValidId(sessionId) && (
        resource == null ||
        resource.data.status in ['waiting', 'linked'] || 
        (isSignedIn() && resource.data.uid == request.auth.uid) ||
        (isSignedIn() && resource.data.get('currentAnonUid', '') == request.auth.uid)
      );
      
      allow list: if false;

      // إنشاء الجلسة من قبل التلفاز
      allow create: if isValidTVSession(request.resource.data) && 
                       request.resource.data.status == 'waiting';
      
      // المستخدم يربط الجلسة بهويته
      allow update: if isSignedIn() &&
                       isValidProfileData(request.resource.data) &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid', 'displayName', 'photoURL', 'status', 'email', 'linkedAt']) &&
                       request.resource.data.status == 'linked' &&
                       request.resource.data.uid == request.auth.uid &&
                       resource.data.status == 'waiting';
      
      allow delete: if isSignedIn() && 
                       resource.data.uid == request.auth.uid;
    }

    // ═══════════════════════════════════════
    // Pairings Collection (الأجهزة المرتبطة)
    // ═══════════════════════════════════════
    
    match /pairings/{deviceId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow list: if isSignedIn() && 
                     resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() &&
                       isValidId(deviceId) &&
                       request.resource.data.keys().hasAll(['userId', 'deviceId', 'lastActive']) &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.deviceId == deviceId &&
                       request.resource.data.lastActive is timestamp;
      
      allow update: if isSignedIn() &&
                       resource.data.userId == request.auth.uid &&
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'deviceId']) &&
                       request.resource.data.lastActive is timestamp;
      
      allow delete: if isSignedIn() && 
                       resource.data.userId == request.auth.uid;
    }
  }
}
