rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && 
             id.size() > 0 &&
             id.size() <= 128 && 
             id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUrl(url) {
      return url is string && 
             url.size() >= 10 &&
             url.size() <= 2048 &&
             (url.matches('^https://.*') || url.matches('^http://.*'));
    }

    function isValidProfileData(data) {
      return data.displayName is string &&
             data.displayName.size() > 0 &&
             data.displayName.size() <= 255 &&
             data.photoURL is string &&
             data.photoURL.size() <= 2048;
    }

    function isValidRemoteUpload(data) {
      return data.keys().hasAll(['deviceId', 'anonUid', 'type', 'url', 'createdAt', 'userId']) &&
             isValidId(data.deviceId) &&
             isValidId(data.anonUid) &&
             data.type in ['image', 'audio', 'video'] &&
             isValidUrl(data.url) &&
             data.userId is string &&
             data.userId.size() > 0 &&
             data.createdAt is timestamp &&
             data.createdAt <= request.time;
    }

    function isValidTVSession(data) {
      return data.keys().hasAll(['status', 'deviceId', 'createdAt']) &&
             data.status in ['waiting', 'linked'] &&
             isValidId(data.deviceId) &&
             data.createdAt is timestamp &&
             data.createdAt <= request.time &&
             (data.get('currentAnonUid', '') is string);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      
      allow create: if isOwner(userId) &&
                       request.resource.data.keys().hasAll(['xp', 'coins', 'donations']) &&
                       request.resource.data.xp is number &&
                       request.resource.data.coins is number &&
                       request.resource.data.donations is number;
      
      allow update: if isOwner(userId) &&
                       (
                         !resource.data.keys().hasAll(['xp', 'coins', 'donations']) ||
                         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdAt'])
                       );
      
      allow delete: if isOwner(userId);

      match /lessons/{lessonId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /uploads/{uploadId} {
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.get('anonUid', '') == request.auth.uid
      );
      
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.get('anonUid', '') == request.auth.uid
      );

      allow create: if isSignedIn() && 
                       isValidRemoteUpload(request.resource.data) &&
                       request.resource.data.userId == request.auth.uid;
      
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow update: if false;
    }

    match /tv_sessions/{sessionId} {
      allow get: if isValidId(sessionId) && (
        resource == null ||
        resource.data.status in ['waiting', 'linked'] || 
        (isSignedIn() && resource.data.uid == request.auth.uid) ||
        (isSignedIn() && resource.data.get('currentAnonUid', '') == request.auth.uid)
      );
      
      allow list: if false;

      allow create: if isValidTVSession(request.resource.data) && 
                       request.resource.data.status == 'waiting';
      
      allow update: if isSignedIn() &&
                       isValidProfileData(request.resource.data) &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid', 'displayName', 'photoURL', 'status', 'email', 'linkedAt']) &&
                       request.resource.data.status == 'linked' &&
                       request.resource.data.uid == request.auth.uid &&
                       resource.data.status == 'waiting';
      
      allow delete: if isSignedIn() && 
                       resource.data.uid == request.auth.uid;
    }

    match /pairings/{deviceId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() &&
                       isValidId(deviceId) &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.deviceId == deviceId;
      
      allow update: if isSignedIn() &&
                       resource.data.userId == request.auth.uid &&
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'deviceId']);
      
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
